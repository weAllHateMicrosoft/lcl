# ─── Database ────────────────────────────────────────────────────────────────
# Prototype phase: local SQLite file, zero setup.
DATABASE_URL="file:./dev.db"
# To mature to Postgres (Neon/Supabase) later, change the provider in
# prisma/schema.prisma to "postgresql" and paste the connection string here.

# ─── Secrets ─────────────────────────────────────────────────────────────────
# Master key used to encrypt LLM provider API keys stored in the DB.
# Generate one with:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY="dev-only-insecure-key-change-me-please-32b"

# ─── LLM (all optional) ──────────────────────────────────────────────────────
# You do NOT need any of these to run — the app defaults to an offline "stub"
# provider so lessons, grading, and the tutor work with canned responses.
# When you get keys, prefer setting them in Admin → Settings (DB-backed, no
# redeploy). These env vars are only a fallback / convenience.
#
# GEMINI_API_KEY=""       # free tier ~1,500 req/day, no card — recommended start
# GROQ_API_KEY=""         # free, very fast, OpenAI-compatible
# OPENROUTER_API_KEY=""   # many free models behind one key
# ANTHROPIC_API_KEY=""
