// classOS data model.
//
// Prototype phase uses SQLite (file-based, zero setup). To mature to Postgres:
//   1. change `provider` below to "postgresql"
//   2. set DATABASE_URL to your Neon/Supabase connection string
//   3. run `npm run db:push`
// Nothing else changes — `Json` maps to JSONB on Postgres automatically.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Curriculum tree (the editable CMS) ──────────────────────────────────────

model Chapter {
  id        String   @id @default(cuid())
  order     Int
  title     String
  lessons   Lesson[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Lesson {
  id        String  @id @default(cuid())
  chapter   Chapter @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  chapterId String
  code      String  @unique // e.g. "2.10" — stable, human-facing, used in URLs
  order     Int
  title     String
  goal      String  @default("")

  // Ordered array of typed blocks. See lib/curriculum/blocks.ts for the shape.
  // No @default: Prisma's Json defaults are broken on SQLite (emits unquoted
  // `DEFAULT []` -> invalid SQL). Every create site supplies these explicitly.
  blocks    Json
  // Graded coding exercise: { prompt, starter, expected, behaviour, stdin }
  exercise  Json
  // Pool the practice + summative quizzes draw from: [{ q, opts[], correct, why }]
  quizBank  Json

  // Learning objectives: string[] — concepts to cover / skills to master.
  // Shown to students, and fed to the AI tutor + question generator as scope.
  objectives Json?

  // Unpublished working copy: { title, goal, objectives, blocks, exercise, quizBank }.
  // Students always read the live fields above; the editor edits this until
  // the owner hits Publish.
  draft    Json?
  draftAt  DateTime?

  attempts  Attempt[]
  versions  LessonVersion[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([chapterId, order])
}

// Snapshot of the live lesson taken at each publish — the undo history.
// Restoring copies a snapshot into the draft (never straight to live).
model LessonVersion {
  id          String   @id @default(cuid())
  lesson      Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  lessonId    String
  snapshot    Json // { title, goal, blocks, exercise, quizBank }
  publishedAt DateTime @default(now())

  @@index([lessonId, publishedAt])
}

// ─── People & roles ──────────────────────────────────────────────────────────

// Role: "ADMIN" | "TEACHER" | "STUDENT". Kept as String because SQLite has no
// native enums; becomes a real Prisma enum when you move to Postgres.
//
// Auth model (decided): staff (ADMIN/TEACHER) sign in with email + password.
// Students have NO email/password — they join a Class with its join code and a
// display name, Kahoot/ClassDojo-style.
model User {
  id           String    @id @default(cuid())
  name         String
  email        String?   @unique // staff only
  passwordHash String? // scrypt "salt:hash" — staff only
  role         String    @default("STUDENT")
  class        Class?    @relation("ClassStudents", fields: [classId], references: [id], onDelete: SetNull)
  classId      String? // students only
  classesOwned Class[]   @relation("ClassTeacher") // staff only
  attempts     Attempt[]
  aiCalls      AiCall[]
  sent         Message[] @relation("MsgFrom")
  inbox        Message[] @relation("MsgTo")
  testsOwned   Test[]    @relation("TestOwner")
  submissions  TestSubmission[]
  avatar       String? // small image as a data URL (profile pic)
  createdAt    DateTime  @default(now())

  @@index([classId])
}

// A test/quiz assembled from typed questions (lib/curriculum/questions.ts).
// Assign to a class; students take it full-screen; results feed grading.
model Test {
  id          String   @id @default(cuid())
  title       String
  owner       User?    @relation("TestOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  ownerId     String?
  class       Class?   @relation(fields: [classId], references: [id], onDelete: SetNull)
  classId     String?
  questions   Json // Question[]
  timeLimit   Int? // minutes, null = untimed
  openAt      DateTime?
  closeAt     DateTime?
  published   Boolean  @default(false) // students can take it
  resultsReleased Boolean @default(false) // students can see their marks + feedback
  submissions TestSubmission[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([classId])
}

model TestSubmission {
  id          String   @id @default(cuid())
  test        Test     @relation(fields: [testId], references: [id], onDelete: Cascade)
  testId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId      String
  answers     Json // { [questionId]: answer }
  results     Json? // QResult[] after grading
  autoScore   Float    @default(0)
  maxScore    Float    @default(0)
  finalScore  Float? // teacher-confirmed total (overrides auto)
  status      String   @default("submitted") // submitted | graded
  submittedAt DateTime @default(now())
  gradedAt    DateTime?

  @@unique([testId, userId])
  @@index([testId])
}

// Direct messages + system notifications share one inbox. kind="dm" is a
// student↔staff message; kind="system" is a platform notice (fromId null).
// Extensible: add kinds (e.g. "graded", "announcement") without schema change.
model Message {
  id         String    @id @default(cuid())
  kind       String    @default("dm")
  fromUser   User?     @relation("MsgFrom", fields: [fromId], references: [id], onDelete: SetNull)
  fromId     String?
  toUser     User      @relation("MsgTo", fields: [toId], references: [id], onDelete: Cascade)
  toId       String
  body       String
  lessonCode String? // optional context (message sent from a lesson)
  readAt     DateTime?
  editedAt   DateTime?
  createdAt  DateTime  @default(now())

  @@index([toId, readAt])
  @@index([fromId])
}

model Class {
  id        String   @id @default(cuid())
  name      String
  joinCode  String   @unique // what students type to join
  teacher   User?    @relation("ClassTeacher", fields: [teacherId], references: [id], onDelete: SetNull)
  teacherId String?
  students  User[]   @relation("ClassStudents")
  tests     Test[]
  createdAt DateTime @default(now())
}

// ─── Tracking (the readiness/mastery engine, now durable) ────────────────────

model Attempt {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  lesson    Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  lessonId  String
  // "QUIZ_PRACTICE" | "QUIZ_GENERATED" | "CODE_RUN" | "QUIZ_SUMMATIVE".
  // Only a passing QUIZ_SUMMATIVE can set MASTERED (see lib/progress.ts).
  kind      String
  passed    Boolean
  score     Float    @default(0) // 0..1
  detail    Json     // per-question results, code, verdict, etc. — always supplied by callers
  createdAt DateTime @default(now())

  @@index([userId, lessonId])
}

// Mastery is derived state, updated only through the one honest chokepoint
// (see lib/progress.ts). Kept as a row so the teacher dashboard reads it cheaply.
model Progress {
  id        String  @id @default(cuid())
  userId    String
  lessonId  String
  status    String  @default("NOT_STARTED") // NOT_STARTED | IN_PROGRESS | MASTERED
  readiness Float   @default(0)             // 0..1 — evidence toward mastery
  flag      String? // "stuck" | "coast" | null
  updatedAt DateTime @updatedAt

  @@unique([userId, lessonId])
}

model AiCall {
  id        String   @id @default(cuid())
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  userId    String?
  feature   String   // tutor | grade | generate | runjava
  provider  String
  model     String
  inTokens  Int      @default(0)
  outTokens Int      @default(0)
  cost      Float    @default(0)
  createdAt DateTime @default(now())

  @@index([createdAt])
}

// ─── Settings (DB-backed config — swap providers without redeploy) ───────────

model Setting {
  key   String @id
  value Json
}
