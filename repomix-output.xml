.btn { border: 1.5px solid var(--ink); background: var(--ink); color: var(--paper); border-radius: 9px; padding: 10px 18px; font-size: 13.5px; font-weight: 700; }
.btn:hover { background: #33362f; }
.btn.ghost { background: transparent; color: var(--ink); } .btn.ghost:hover { background: #eee9de; }
.btn.green { background: var(--accent); border-color: var(--accent); }
.btn.orange { background: var(--accent-2); border-color: var(--accent-2); }
.btn.purple { background: var(--violet); border-color: var(--violet); }
.btn.blue { background: #2a6f97; border-color: #2a6f97; }
.btn:disabled { opacity: .45; cursor: not-allowed; }

/* ─── Quiz ─── */
.qitem { margin-bottom: 18px; padding-bottom: 16px; border-bottom: 1px dashed var(--line); }
.qitem:last-of-type { border-bottom: none; }
.qitem .qh { font-weight: 700; margin-bottom: 9px; }
.qitem .qh .n { font-family: var(--mono); font-size: 11px; color: var(--accent-2); margin-right: 8px; }
.opt { display: flex; gap: 12px; align-items: flex-start; width: 100%; text-align: left; border: 1.5px solid var(--line); border-radius: 10px; padding: 10px 13px; margin-bottom: 7px; cursor: pointer; background: #fdfcf9; font-size: 14px; }
.opt:hover { border-color: var(--ink); }
.opt.sel { border-color: var(--ink); background: #f1eee6; box-shadow: 2px 2px 0 rgba(26,28,30,.12); }
.opt.right { border-color: var(--ok); background: #e7f2ec; }
.opt.wrong { border-color: var(--bad); background: #f7e9e6; }
.opt .letter { font-family: var(--mono); font-weight: 600; font-size: 12px; background: var(--ink); color: #fff; border-radius: 6px; padding: 2px 7px; flex-shrink: 0; }
.why { font-size: 13px; margin: 4px 0 0; padding: 8px 12px; border-radius: 8px; background: #f1eee6; border-left: 3px solid var(--accent); }
.quizfoot { display: flex; gap: 10px; align-items: center; flex-wrap: wrap; margin-top: 6px; }
.score { font-family: var(--mono); font-weight: 600; font-size: 13px; }
.score.ok { color: var(--ok); } .score.bad { color: var(--bad); }

/* ─── Code editor + console ─── */
.cm-wrap { border-radius: 10px; overflow: hidden; border: 1.5px solid #2a2d25; }
.cm-wrap .cm-editor { font-family: var(--mono); font-size: 13px; }
.runrow { display: flex; gap: 10px; margin-top: 12px; align-items: center; flex-wrap: wrap; }
.runnote { font-family: var(--mono); font-size: 10.5px; color: var(--muted); }
.console { margin-top: 12px; background: #12140f; border: 1.5px solid #2a2d25; border-radius: 10px; overflow: hidden; }
.console .chead { background: #1e211f; color: #8b9186; font-family: var(--mono); font-size: 10.5px; letter-spacing: .1em; padding: 7px 14px; display: flex; justify-content: space-between; border-bottom: 1px solid #2a2d25; }
.console .cbody { font-family: var(--mono); font-size: 13px; color: #cfe3c9; padding: 14px 16px; white-space: pre-wrap; min-height: 44px; line-height: 1.5; }
.console .cbody.err { color: #f0a08f; }
.console .cbody .mutedtx { color: #6b7268; }
.stdinrow { display: flex; gap: 8px; align-items: center; margin-top: 10px; flex-wrap: wrap; }
.stdinrow input { border: 1.5px solid var(--ink); border-radius: 8px; padding: 8px 12px; font-family: var(--mono); font-size: 12.5px; background: #fdfcf9; min-width: 240px; }
.stdinrow label { font-family: var(--mono); font-size: 10.5px; color: var(--muted); }

/* ─── Grade mode toggle (v4's two honest modes) ─── */
.modeseg { display: inline-flex; border: 1.5px solid var(--ink); border-radius: 9px; overflow: hidden; margin-bottom: 6px; }
.modeseg button { background: #fdfcf9; border: none; padding: 8px 14px; font-size: 12.5px; font-weight: 600; color: var(--muted); }
.modeseg button.on { background: var(--ink); color: var(--paper); }
.modehint { font-family: var(--mono); font-size: 10.5px; color: var(--muted); margin: 4px 0 12px; }

/* ─── Grading results ─── */
.tests { margin-top: 14px; }
.test { display: flex; gap: 10px; align-items: flex-start; font-family: var(--mono); font-size: 12.5px; padding: 10px 12px; border-radius: 8px; margin-bottom: 6px; border: 1px solid var(--line); background: #fdfcf9; }
.test.pass { border-color: var(--ok); background: #e7f2ec; }
.test.fail { border-color: var(--bad); background: #f7e9e6; }
.test .mark { font-weight: 700; flex-shrink: 0; }
.diff { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; margin-top: 8px; }
.diff .box { border: 1px solid var(--line); border-radius: 8px; overflow: hidden; background: #fff; }
.diff .box h5 { font-family: var(--mono); font-size: 9.5px; letter-spacing: .1em; text-transform: uppercase; color: var(--muted); padding: 6px 10px; background: #f1eee6; border-bottom: 1px solid var(--line); }
.diff .box pre { font-family: var(--mono); font-size: 12px; padding: 9px 11px; white-space: pre-wrap; line-height: 1.45; }
.aigrade { margin-top: 12px; padding: 14px 16px; border-radius: 10px; border-left: 3px solid var(--violet); background: #eef0f7; font-size: 13.5px; }
.aigrade .verdict { font-weight: 700; font-family: var(--mono); font-size: 11px; letter-spacing: .08em; margin-bottom: 6px; display: block; }
.aigrade .verdict.ok { color: var(--ok); } .aigrade .verdict.bad { color: var(--bad); }
.aigrade .m { display: block; margin-top: 8px; font-family: var(--mono); font-size: 10px; color: var(--muted); }

/* ─── Generate + tutor ─── */
.genrow { display: flex; gap: 8px; flex-wrap: wrap; margin-bottom: 10px; }
.genrow input { flex: 1; min-width: 220px; border: 1.5px solid var(--ink); border-radius: 9px; padding: 10px 14px; font-family: inherit; font-size: 14px; background: #fdfcf9; }
.genhint { font-family: var(--mono); font-size: 10.5px; color: var(--muted); line-height: 1.6; }
.offline-note { margin: 10px 0; padding: 12px 16px; border-radius: 10px; border-left: 4px solid var(--warn); background: #fbf3e2; font-size: 13.5px; }
.tutor .quick { display: flex; gap: 8px; flex-wrap: wrap; margin-bottom: 12px; }
.chip { border: 1.5px solid var(--ink); background: #fdfcf9; border-radius: 99px; padding: 7px 14px; font-size: 12.5px; font-weight: 600; }
.chip:hover { background: var(--ink); color: #fff; }
.askrow { display: flex; gap: 8px; }
.askrow input { flex: 1; border: 1.5px solid var(--ink); border-radius: 9px; padding: 10px 14px; font-family: inherit; font-size: 14px; background: #fdfcf9; }
.msgs { max-height: 360px; overflow-y: auto; margin-bottom: 14px; display: flex; flex-direction: column; gap: 10px; }
.msg { border-radius: 12px; padding: 12px 15px; font-size: 14px; max-width: 92%; white-space: pre-wrap; }
.msg.u { background: var(--ink); color: var(--paper); align-self: flex-end; }
.msg.a { background: #e7f2ec; border: 1px solid var(--ok); align-self: flex-start; }
.msg.a .who { font-family: var(--mono); font-size: 10px; letter-spacing: .1em; color: var(--accent); display: block; margin-bottom: 5px; font-weight: 600; }
.msg.a .meta { display: block; margin-top: 8px; font-family: var(--mono); font-size: 10px; color: var(--muted); }
.msg.think { color: var(--muted); font-style: italic; background: #f1eee6; border: 1px dashed var(--line); }
.scopenote { font-family: var(--mono); font-size: 10.5px; color: var(--muted); margin-top: 10px; line-height: 1.6; }

/* ─── Teacher dashboard ─── */
.dash { flex: 1; padding: 28px 34px; }
.kpis { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; margin-bottom: 22px; }
.kpi { background: var(--ink); color: var(--paper); border-radius: 12px; padding: 18px 20px; }
.kpi .n { font-family: var(--serif); font-size: 30px; font-weight: 900; color: #e9e4d8; }
.kpi .n em { color: #7fd6b8; font-style: normal; }
.kpi p { font-size: 12.5px; color: #b9bcb2; margin-top: 2px; }
.dashgrid { background: var(--card); border: 1.5px solid var(--ink); border-radius: 14px; overflow: auto; box-shadow: 4px 4px 0 rgba(26,28,30,.08); }
table { width: 100%; border-collapse: collapse; font-size: 14px; }
th { font-family: var(--mono); font-size: 10.5px; letter-spacing: .1em; text-transform: uppercase; text-align: left; padding: 13px 16px; background: #f1eee6; border-bottom: 1.5px solid var(--ink); color: var(--muted); }
td { padding: 12px 16px; border-bottom: 1px solid var(--line); }
tr:last-child td { border-bottom: none; }
td.name { font-weight: 700; }
.cellpill { display: inline-flex; align-items: center; gap: 7px; font-family: var(--mono); font-size: 11px; padding: 4px 11px; border-radius: 99px; font-weight: 600; white-space: nowrap; }
.cellpill.m { background: #e7f2ec; color: var(--ok); border: 1px solid var(--ok); }
.cellpill.p { background: #fbf3e2; color: #9a6c0d; border: 1px solid var(--warn); }
.cellpill.n { background: #f1eee6; color: var(--muted); border: 1px solid var(--line); }
.flag { font-size: 11px; font-weight: 700; color: #fff; background: var(--bad); border-radius: 6px; padding: 2px 8px; margin-left: 8px; font-family: var(--mono); }
.flag.coast { background: var(--violet); }
.dashnote { margin-top: 16px; font-size: 13px; color: var(--muted); max-width: 75ch; }

/* ─── Summative overlay (SEB) ─── */
.overlay { position: fixed; inset: 0; background: rgba(26,28,30,.72); display: flex; align-items: center; justify-content: center; z-index: 50; padding: 20px; }
.sebwin { background: var(--paper); border-radius: 16px; max-width: 680px; width: 100%; max-height: 92vh; overflow-y: auto; border: 2px solid var(--ink); }
.sebbar { background: var(--bad); color: #fff; font-family: var(--mono); font-size: 11px; letter-spacing: .12em; padding: 10px 18px; display: flex; justify-content: space-between; border-radius: 13px 13px 0 0; flex-wrap: wrap; gap: 6px; }
.sebbody { padding: 26px 28px; }
.sebbody h2 { font-family: var(--serif); font-size: 24px; font-weight: 900; margin-bottom: 6px; }
.sebbody .sub { font-size: 13px; color: var(--muted); margin-bottom: 18px; }
.sebres { margin-top: 14px; padding: 16px 18px; border-radius: 10px; font-weight: 600; }
.sebres.pass { background: #e7f2ec; border: 1.5px solid var(--ok); color: var(--ok); }
.sebres.fail { background: #f7e9e6; border: 1.5px solid var(--bad); color: var(--bad); }

/* ─── Editor (ported from classOS-editor) ─── */
.ednav { width: 262px; flex-shrink: 0; border-right: 1.5px solid var(--line); background: #f1eee6; min-height: calc(100vh - 57px); overflow-y: auto; padding: 16px 12px; }
.chap { margin-bottom: 14px; }
.chaphead { display: flex; align-items: center; gap: 6px; padding: 0 6px 6px; }
.chaphead input { flex: 1; font-family: var(--mono); font-size: 11px; letter-spacing: .08em; text-transform: uppercase; color: var(--muted); background: transparent; border: none; font-weight: 700; }
.chaphead input:focus { outline: 1px solid var(--accent); border-radius: 4px; background: #fff; }
.lrow { display: flex; gap: 8px; align-items: center; width: 100%; text-align: left; background: transparent; border: 1.5px solid transparent; border-radius: 8px; padding: 8px 9px; font-size: 13.5px; font-weight: 500; color: var(--ink); cursor: pointer; }
.lrow:hover { background: #e9e5da; }
.lrow.on { background: var(--card); border-color: var(--ink); box-shadow: 2px 2px 0 rgba(26,28,30,.1); font-weight: 700; }
.lrow .num { font-family: var(--mono); font-size: 10.5px; color: var(--accent); font-weight: 600; }
.addbtn { width: 100%; text-align: left; background: transparent; border: 1px dashed var(--line); border-radius: 8px; padding: 7px 10px; font-size: 12.5px; color: var(--muted); margin-top: 3px; }
.addbtn:hover { border-color: var(--accent); color: var(--accent); }
.edmain { flex: 1; max-width: 860px; margin: 0 auto; padding: 26px 34px 120px; }
.edbar { display: flex; align-items: center; gap: 10px; flex-wrap: wrap; margin-bottom: 18px; }
.edbar .seg { display: flex; border: 1.5px solid var(--ink); border-radius: 9px; overflow: hidden; }
.edbar .seg button { background: #fdfcf9; border: none; padding: 8px 15px; font-size: 13px; font-weight: 600; color: var(--muted); }
.edbar .seg button.on { background: var(--ink); color: var(--paper); }
.edbar .save { font-family: var(--mono); font-size: 11px; color: var(--accent); }
.lhead { display: flex; gap: 10px; margin-bottom: 8px; }
.lhead input { border: 1.5px solid var(--line); border-radius: 8px; padding: 9px 12px; font-family: inherit; background: #fff; }
.lhead .lcode { width: 76px; font-family: var(--mono); font-size: 13px; }
.lhead .ltitle { flex: 1; font-family: var(--serif); font-weight: 700; font-size: 20px; }
.goalin { width: 100%; border: 1.5px solid var(--line); border-radius: 8px; padding: 9px 12px; font-family: inherit; font-size: 14px; background: #fff; margin-bottom: 18px; }
.blk { border: 1.5px solid var(--line); border-radius: 12px; margin-bottom: 12px; background: #fff; overflow: hidden; }
.blk.dragover { border-color: var(--accent); box-shadow: 0 -3px 0 var(--accent); }
.blk.dragging { opacity: .4; }
.blk .bh { display: flex; align-items: center; gap: 8px; background: #f1eee6; padding: 6px 10px; border-bottom: 1px solid var(--line); }
.blk .bh .grip { cursor: grab; color: var(--muted); font-size: 14px; padding: 0 4px; user-select: none; }
.blk .bh .grip:active { cursor: grabbing; }
.blk .bh .kind { font-family: var(--mono); font-size: 10px; letter-spacing: .1em; text-transform: uppercase; font-weight: 700; color: var(--muted); }
.blk .bh .sp { flex: 1; }
.blk .bh button { background: #fff; border: 1px solid var(--line); border-radius: 6px; width: 26px; height: 24px; font-size: 12px; color: var(--muted); display: inline-flex; align-items: center; justify-content: center; }
.blk .bh button:hover { border-color: var(--ink); color: var(--ink); }
.blk .bh button.del:hover { border-color: var(--accent-2); color: var(--accent-2); }
.blk .bb { padding: 12px 14px; }
.blk textarea, .blk input.f { width: 100%; border: 1px solid var(--line); border-radius: 8px; padding: 9px 11px; font-family: inherit; font-size: 14px; background: #fdfcf9; resize: vertical; }
.blk textarea.monoarea { font-family: var(--mono); font-size: 13px; background: #1e211f; color: #dfe6db; border: none; min-height: 90px; line-height: 1.55; }
.blk .lbl { font-family: var(--mono); font-size: 9.5px; letter-spacing: .08em; text-transform: uppercase; color: var(--muted); margin: 8px 0 4px; }
.blk .lbl:first-child { margin-top: 0; }
.blk select { border: 1px solid var(--line); border-radius: 7px; padding: 6px 9px; font-family: inherit; font-size: 13px; background: #fff; }
.itemrow { display: flex; gap: 6px; margin-bottom: 6px; }
.itemrow input { flex: 1; }
.itemrow input:first-child { flex: 0 0 180px; font-family: var(--mono); font-size: 12.5px; }
.itemrow button { background: #fff; border: 1px solid var(--line); border-radius: 6px; width: 28px; color: var(--muted); }
.itemrow button:hover { border-color: var(--accent-2); color: var(--accent-2); }
.addbar { display: flex; gap: 7px; flex-wrap: wrap; margin: 16px 0; padding: 14px; border: 1.5px dashed var(--accent); border-radius: 12px; background: #fbfdfb; }
.addbar .lbl { width: 100%; font-family: var(--mono); font-size: 10px; letter-spacing: .08em; text-transform: uppercase; color: var(--accent); margin-bottom: 2px; }
.addbar button { border: 1.5px solid var(--ink); background: #fff; border-radius: 8px; padding: 7px 13px; font-size: 12.5px; font-weight: 600; }
.addbar button:hover { background: var(--ink); color: var(--paper); }
.pv h1 { font-family: var(--serif); font-weight: 900; font-size: 30px; margin-bottom: 8px; line-height: 1.1; }

/* ─── Student tool launcher rail ─── */
.dockrail { position: fixed; right: 0; top: 38%; display: flex; flex-direction: column; gap: 8px; z-index: 40; }
.dockrail button { writing-mode: vertical-rl; background: var(--ink); color: var(--paper); border: 1.5px solid var(--ink); border-right: none; border-radius: 10px 0 0 10px; padding: 16px 9px; font-size: 12.5px; font-weight: 700; letter-spacing: .04em; box-shadow: -3px 3px 0 rgba(26,28,30,.15); }
.dockrail button:hover, .dockrail button.on { background: var(--accent); border-color: var(--accent); }

/* ─── Floating / dockable tool windows ─── */
.toolwin { background: var(--paper); border: 1.5px solid var(--ink); display: flex; flex-direction: column; box-shadow: 4px 6px 0 rgba(26,28,30,.14); overflow: hidden; }
.toolwin.floating { border-radius: 14px; }
.toolwin.docked { border-radius: 0; border-right: none; box-shadow: -8px 0 28px rgba(26,28,30,.16); }
.toolbar { display: flex; align-items: center; gap: 8px; padding: 8px 10px 8px 14px; background: var(--ink); color: var(--paper); cursor: grab; user-select: none; touch-action: none; }
.toolbar:active { cursor: grabbing; }
.toolbar .ttitle { font-family: var(--mono); font-size: 11.5px; letter-spacing: .06em; font-weight: 700; }
.toolbar .tctl { background: transparent; color: #b9bcb2; border: 1px solid #4a4d47; border-radius: 6px; width: 26px; height: 24px; font-size: 12px; }
.toolbar .tctl:hover { background: #33372f; color: #fff; }
.toolbody { flex: 1; overflow-y: auto; padding: 16px; min-height: 0; }
.resizer { position: absolute; }
.resizer.corner { right: 0; bottom: 0; width: 18px; height: 18px; cursor: nwse-resize; background: linear-gradient(135deg, transparent 50%, var(--muted) 50%, var(--muted) 60%, transparent 60%); }
.resizer.left { left: 0; top: 0; bottom: 0; width: 7px; cursor: ew-resize; }
.resizer.left:hover { background: var(--accent); }

/* ─── Highlight-to-ask composer ─── */
.askpop2 { position: fixed; transform: translateX(-50%); z-index: 60; background: var(--paper); border: 1.5px solid var(--ink); border-radius: 12px; padding: 10px; width: 340px; box-shadow: 4px 6px 0 rgba(26,28,30,.16); display: flex; flex-direction: column; gap: 7px; }
.askpop2 .quoteprev { font-size: 12px; color: var(--muted); font-style: italic; border-left: 3px solid var(--violet); padding-left: 8px; }
.askpop2 input { border: 1.5px solid var(--line); border-radius: 8px; padding: 8px 11px; font-family: inherit; font-size: 13.5px; background: #fdfcf9; }
.sentnote { position: fixed; bottom: 24px; left: 50%; transform: translateX(-50%); z-index: 60; background: var(--accent); color: #fff; border-radius: 10px; padding: 10px 18px; font-size: 13.5px; font-weight: 600; box-shadow: 0 6px 18px rgba(26,28,30,.3); }

/* ─── Scratchpad v2 layout ─── */
.padgrid { flex: 1; display: flex; gap: 10px; min-height: 200px; flex-wrap: wrap; }
.padcode { flex: 1 1 320px; min-width: 280px; min-height: 200px; display: flex; }
.padcode .cm-wrap { flex: 1; display: flex; flex-direction: column; }
.padcode .cm-wrap > div { flex: 1; }
.padgrid .console { flex: 1 1 240px; min-width: 220px; min-height: 160px; }
.padai { border-top: 1.5px dashed var(--line); padding-top: 10px; }
.padai-msgs { max-height: 180px; overflow-y: auto; display: flex; flex-direction: column; gap: 6px; margin-bottom: 8px; }

/* ─── Questions (view + build) ─── */
.qcard { border: 1.5px solid var(--line); border-radius: 12px; padding: 16px 18px; margin-bottom: 14px; background: #fff; }
.qcard.info { background: #eef0f7; border-left: 4px solid var(--violet); }
.qedit { display: flex; flex-direction: column; gap: 6px; }
.qedit-head { display: flex; gap: 8px; align-items: flex-start; }
.qedit-head .pts { font-family: var(--mono); font-size: 10px; color: var(--muted); display: flex; flex-direction: column; align-items: center; gap: 2px; }
.qedit-head .pts input { width: 52px; text-align: center; }
.qbuild.dragging { opacity: .4; }
.qbuild.dragover { box-shadow: 0 -4px 0 var(--accent), 4px 4px 0 rgba(26,28,30,.08); }
.qbuild-head { display: flex; align-items: center; gap: 6px; margin-bottom: 10px; }
.qbuild-head .qtype { font-family: var(--mono); font-size: 11px; font-weight: 700; color: var(--violet); }
.testsettings { display: grid; grid-template-columns: 1fr 130px 1fr; gap: 12px; margin-bottom: 8px; }
.gradeans { background: #f1eee6; border-radius: 8px; padding: 8px 12px; margin: 6px 0; font-size: 14px; }
.graderow { display: flex; align-items: center; gap: 8px; margin-top: 8px; }
.graderow input[type="number"] { width: 60px; padding: 6px; border: 1.5px solid var(--ink); border-radius: 7px; text-align: center; }

/* ─── Full-screen exam ─── */
.examwrap { min-height: calc(100vh - 57px); background: var(--paper); }
.exambody { max-width: 760px; margin: 0 auto; padding: 34px 24px 80px; }

/* ─── Objectives ─── */
.objectives { border: 1.5px solid var(--line); border-left: 4px solid var(--violet); border-radius: 0 10px 10px 0; background: #eef0f7; padding: 12px 18px; margin: 0 0 18px; }
.objectives .ch { font-family: var(--mono); font-size: 10.5px; letter-spacing: .08em; font-weight: 700; color: var(--violet); margin-bottom: 6px; }
.objectives ul { margin: 0 0 0 20px; font-size: 14.5px; }
.objectives li { margin: 3px 0; }

/* ─── Message extras ─── */
.msgrow { position: relative; }
.msgrow .msgacts { display: none; position: absolute; top: 4px; right: 6px; gap: 3px; }
.msgrow:hover .msgacts { display: inline-flex; }
.msgrow .msgacts button { border: none; background: rgba(255,255,255,.85); border-radius: 5px; width: 22px; height: 20px; font-size: 11px; cursor: pointer; color: var(--ink); }
.lessonref { display: block; margin-top: 6px; font-family: var(--mono); font-size: 11px; color: var(--accent); text-decoration: underline; }
.msg.u .lessonref { color: #7fd6b8; }
.confirmbar { display: flex; align-items: center; gap: 8px; padding: 10px 14px; background: #fbeceb; border-top: 1.5px solid var(--accent-2); font-size: 13px; }
.quoteline { display: block; background: #fdf2b8; color: var(--ink); border-left: 3px solid var(--warn); padding: 5px 10px; margin: 4px 0; border-radius: 0 6px 6px 0; font-style: italic; }
.msg.u .quoteline { background: rgba(255,255,255,.9); }

/* message rows with avatars */
.msgline { display: flex; align-items: flex-end; gap: 8px; max-width: 92%; }
.msgline.mine { align-self: flex-end; flex-direction: row-reverse; }
.msgline.theirs { align-self: flex-start; }
.msgline .msg { max-width: 100%; }

/* lesson passage the teacher jumped to */
.lesson-highlight { background: #fde68a; color: var(--ink); border-radius: 3px; padding: 1px 2px; box-shadow: 0 0 0 3px #fde68a; animation: hlpulse 1.4s ease 2; }
@keyframes hlpulse { 0%,100% { background: #fde68a; } 50% { background: #fbbf24; } }

/* avatar cropper */
.cropview { position: relative; margin: 0 auto; overflow: hidden; border-radius: 12px; background: #000; touch-action: none; cursor: grab; }
.cropview:active { cursor: grabbing; }
.cropring { position: absolute; inset: 0; border-radius: 999px; box-shadow: 0 0 0 999px rgba(22,24,28,.55); pointer-events: none; }

/* ─── Inline lesson editor (edit-while-previewing) ─── */
.edblk { position: relative; border-radius: 8px; }
.edblk:hover, .edblk:focus-within { outline: 1.5px dashed #c9d6cf; outline-offset: 6px; }
.edblk.dragging { opacity: .35; }
.edblk.dragover { box-shadow: 0 -4px 0 var(--accent); }
.blktools { position: absolute; top: -13px; right: 6px; display: none; gap: 4px; z-index: 5; background: var(--paper); border: 1px solid var(--line); border-radius: 8px; padding: 3px 5px; box-shadow: 2px 2px 0 rgba(26,28,30,.1); }
.edblk:hover .blktools, .edblk:focus-within .blktools { display: flex; }
.blktools button, .blktools select { border: 1px solid var(--line); background: #fff; border-radius: 5px; min-width: 24px; height: 22px; font-size: 11px; color: var(--muted); }
.blktools button:hover { border-color: var(--ink); color: var(--ink); }
.blktools button.del:hover { border-color: var(--accent-2); color: var(--accent-2); }
.blktools .grip { cursor: grab; user-select: none; }
[contenteditable] { outline: none; border-radius: 4px; }
[contenteditable]:focus { background: rgba(13,92,70,.045); box-shadow: 0 0 0 2px rgba(13,92,70,.18); }
[contenteditable]:empty:before { content: attr(data-ph); color: #b5b9ae; }
.insrow { display: flex; align-items: center; gap: 8px; height: 18px; margin: 2px 0; opacity: 0; transition: opacity .12s; }
.insrow:hover, .insrow.open { opacity: 1; }
.insrow .line { flex: 1; border-top: 1.5px dashed var(--accent); }
.insrow .plus { border: 1.5px solid var(--accent); background: #fff; color: var(--accent); border-radius: 99px; width: 22px; height: 22px; font-size: 14px; line-height: 1; font-weight: 700; }
.insrow .plus:hover { background: var(--accent); color: #fff; }
.insmenu { display: flex; gap: 5px; flex-wrap: wrap; }
.insmenu button { border: 1.5px solid var(--ink); background: #fff; border-radius: 7px; padding: 4px 10px; font-size: 11.5px; font-weight: 600; }
.insmenu button:hover { background: var(--ink); color: var(--paper); }
.fmtbar { position: fixed; z-index: 60; display: flex; gap: 3px; background: var(--ink); border-radius: 8px; padding: 4px 5px; box-shadow: 0 4px 14px rgba(26,28,30,.3); }
.fmtbar button { background: transparent; color: var(--paper); border: none; border-radius: 5px; min-width: 26px; height: 24px; font-size: 12.5px; }
.fmtbar button:hover { background: #33362f; }
.codeedit { width: 100%; font-family: var(--mono); font-size: 13.5px; background: #1e211f; color: #dfe6db; border: none; padding: 14px 16px; line-height: 1.55; resize: vertical; min-height: 60px; display: block; }
.outedit { display: flex; align-items: baseline; gap: 10px; background: #0f120d; border-top: 1px dashed #2a2d25; padding: 6px 16px; }
.outedit .lbl { color: #6b7268; font-family: var(--mono); font-size: 9.5px; letter-spacing: .1em; }
.outedit textarea { flex: 1; background: transparent; border: none; color: #b7d3ad; font-family: var(--mono); font-size: 12.5px; resize: vertical; min-height: 20px; outline: none; }
.statuschip { font-family: var(--mono); font-size: 10.5px; letter-spacing: .08em; padding: 5px 12px; border-radius: 99px; font-weight: 700; }
.statuschip.draft { background: #fbf3e2; color: #9a6c0d; border: 1.5px solid var(--warn); }
.statuschip.live { background: #e7f2ec; color: var(--ok); border: 1.5px solid var(--ok); }
.histpanel { border: 1.5px solid var(--ink); border-radius: 12px; background: #fff; padding: 14px 16px; margin-bottom: 16px; box-shadow: 3px 3px 0 rgba(26,28,30,.08); }
.histpanel .vrow { display: flex; align-items: center; gap: 10px; padding: 8px 0; border-bottom: 1px dashed var(--line); font-size: 13px; }
.histpanel .vrow:last-child { border-bottom: none; }
.draftdot { width: 7px; height: 7px; border-radius: 99px; background: var(--warn); flex-shrink: 0; margin-left: auto; }
.edh2 { font-family: var(--serif); font-weight: 700; font-size: 21px; margin: 26px 0 10px; padding-bottom: 5px; border-bottom: 2px solid var(--line); }

/* ─── Nav message badge ─── */
.navbadge { position: absolute; top: -6px; right: -6px; background: var(--accent-2); color: #fff; font-family: var(--mono); font-size: 9px; font-weight: 700; min-width: 16px; height: 16px; border-radius: 99px; display: inline-flex; align-items: center; justify-content: center; padding: 0 4px; }

/* ─── Teacher class cards ─── */
.classcard { border: 1.5px solid var(--line); border-radius: 12px; padding: 12px 14px; margin-bottom: 12px; background: #fdfcf9; }
.cchead { display: flex; align-items: center; gap: 10px; flex-wrap: wrap; }
.tbtn2 { border: 1px solid var(--line); background: #fff; border-radius: 7px; min-width: 28px; height: 28px; padding: 0 8px; font-size: 13px; color: var(--muted); display: inline-flex; align-items: center; justify-content: center; text-decoration: none; }
.tbtn2:hover { border-color: var(--ink); color: var(--ink); }
.tbtn2.danger:hover { border-color: var(--accent-2); color: var(--accent-2); }
.roster { margin-top: 10px; border-top: 1px dashed var(--line); padding-top: 8px; }
.rstudent { display: flex; align-items: center; gap: 8px; padding: 5px 0; font-size: 14px; }

/* ─── Inbox ─── */
.inbox { display: grid; grid-template-columns: 260px 1fr; gap: 0; border: 1.5px solid var(--ink); border-radius: 14px; overflow: hidden; min-height: 460px; box-shadow: 4px 4px 0 rgba(26,28,30,.08); background: #fff; }
.inbox .convos { border-right: 1.5px solid var(--line); background: #f1eee6; overflow-y: auto; }
.inbox .newmsg { padding: 10px; border-bottom: 1px solid var(--line); }
.inbox .newmsg select { width: 100%; padding: 8px; border-radius: 8px; border: 1.5px solid var(--ink); background: #fff; font-family: inherit; font-size: 13px; }
.inbox .convo { display: block; width: 100%; text-align: left; background: transparent; border: none; border-bottom: 1px solid var(--line); padding: 10px 12px; cursor: pointer; }
.inbox .convo:hover { background: #e9e5da; }
.inbox .convo.on { background: #fff; box-shadow: inset 3px 0 0 var(--accent); }
.inbox .crow { display: flex; align-items: center; gap: 8px; }
.inbox .ubadge { margin-left: auto; background: var(--accent-2); color: #fff; font-family: var(--mono); font-size: 9px; font-weight: 700; padding: 1px 6px; border-radius: 99px; }
.inbox .cprev { color: var(--muted); font-size: 12px; margin-top: 3px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.inbox .thread { display: flex; flex-direction: column; }
.inbox .empty { margin: auto; color: var(--muted); }
.inbox .thead { padding: 12px 16px; border-bottom: 1.5px solid var(--line); font-family: var(--serif); font-weight: 700; font-size: 16px; }
.inbox .tmsgs { flex: 1; overflow-y: auto; padding: 16px; display: flex; flex-direction: column; gap: 8px; max-height: 420px; }
.inbox .tmsgs .msg { max-width: 78%; }

/* ─── Auth pages ─── */
.authwrap { min-height: calc(100vh - 57px); display: flex; align-items: flex-start; justify-content: center; padding: 60px 20px; }
.authcard { width: 100%; max-width: 420px; }
.authalt { margin-top: 16px; padding-top: 14px; border-top: 1px dashed var(--line); font-size: 13.5px; color: var(--muted); }
.authalt a { color: var(--accent); font-weight: 600; }
.codein { font-family: var(--mono); font-size: 18px; letter-spacing: .25em; text-transform: uppercase; text-align: center; }

/* ─── Settings / forms ─── */
label.field { display: block; margin: 14px 0; }
label.field .l { font-size: 13px; font-weight: 600; margin-bottom: 5px; display: block; }
label.field .hint { font-size: 12px; color: var(--muted); font-weight: 400; }
input.f, select.f, textarea.f { width: 100%; padding: 9px 12px; border-radius: 8px; border: 1.5px solid var(--line); font-size: 14px; font-family: var(--sans); background: #fdfcf9; }
.notice { background: #eef0f7; border-left: 4px solid var(--violet); border-radius: 0 8px 8px 0; padding: 12px 16px; font-size: 13px; margin: 14px 0; }
.meta { font-family: var(--mono); font-size: 10.5px; color: var(--muted); margin-top: 8px; }

@media (max-width: 840px) {
  .side, .ednav { display: none; }
  .main, .dash, .edmain { padding: 20px; }
  .kpis { grid-template-columns: 1fr; }
  .diff { grid-template-columns: 1fr; }
}
