/* =========================================================================
   LESSON EDITOR — demonstrates the CMS / "freedom to edit" layer.
   Curriculum is a tree of chapters -> lessons -> blocks, persisted in
   window.storage (per-user). In the real platform this same tree lives in
   Postgres and this exact editor UI writes to it via the admin API.
   ========================================================================= */
const BLOCK_KINDS = {
  h:      {label:"Heading"},
  p:      {label:"Text"},
  code:   {label:"Code + output"},
  callout:{label:"Callout"},
  try:    {label:"Exercise"},
};
function seed(){return {chapters:[
  {id:"ch1", title:"Chapter 1 · Basic Java", lessons:[
    {id:"l1", code:"2.10", title:"While Loops",
     goal:"Repeat code an <b>unknown</b> number of times — as long as a condition stays true.",
     blocks:[
       {type:"p", html:"A <strong>while</strong> loop repeats a block <em>as long as a condition is true</em>. Use it when you don't know in advance how many repetitions you need."},
       {type:"code", code:'int count = 0;\nwhile (count < 3) {\n    System.out.println("Hello!");\n    count++;\n}', out:"Hello!\nHello!\nHello!"},
       {type:"callout", kind:"mistake", title:"The infinite loop", html:"If nothing inside the loop moves the condition toward false, it runs forever. The classic cause is forgetting the update line."},
       {type:"try", html:"Read an integer n and print n down to 1 using a while loop.", meta:"stdin: one integer"}
     ]},
    {id:"l2", code:"2.11", title:"If Statements",
     goal:"Make decisions with <b>if</b>, <b>else if</b>, and <b>else</b>.",
     blocks:[{type:"p", html:"An <strong>if statement</strong> lets a program choose what to do based on a condition."}]}
  ]}
]};}

let data, mode='edit', sel={c:0,l:0}, dirty=false;

/* ---------- persistence (window.storage; falls back to memory) ---------- */
async function load(){
  try{ const r=await window.storage.get('curriculum'); data = r? JSON.parse(r.value) : seed(); }
  catch(e){ data = seed(); }
  render();
}
async function save(){
  dirty=true; document.getElementById('saveState').textContent='saving…';
  try{ await window.storage.set('curriculum', JSON.stringify(data)); document.getElementById('saveState').textContent='saved ✓'; }
  catch(e){ document.getElementById('saveState').textContent='saved (memory only)'; }
}
function touch(){ save(); }

/* ---------- helpers ---------- */
const curLesson=()=>data.chapters[sel.c].lessons[sel.l];
function uid(){return 'x'+Math.random().toString(36).slice(2,8);}

/* ---------- nav ---------- */
function render(){ buildNav(); mode==='edit'?renderEdit():renderPreview();
  document.getElementById('segEdit').classList.toggle('on',mode==='edit');
  document.getElementById('segPrev').classList.toggle('on',mode==='preview'); }
function buildNav(){
  let h='';
  data.chapters.forEach((ch,ci)=>{
    h+=`<div class="chap"><div class="chaphead"><input value="${escAttr(ch.title)}" onchange="renameChapter(${ci}, this.value)"></div>`;
    ch.lessons.forEach((L,li)=>{ h+=`<button class="lrow ${ci===sel.c&&li===sel.l?'on':''}" onclick="pick(${ci},${li})"><span class="num">${escHtml(L.code)}</span><span>${escHtml(L.title)}</span></button>`; });
    h+=`<button class="addbtn" onclick="addLesson(${ci})">+ add lesson</button></div>`;
  });
  h+=`<button class="addbtn" style="border-style:solid;font-weight:600" onclick="addChapter()">+ add chapter</button>`;
  document.getElementById('nav').innerHTML=h;
}
function pick(c,l){ sel={c,l}; render(); }
function addChapter(){ data.chapters.push({id:uid(),title:"New Chapter",lessons:[{id:uid(),code:"0.0",title:"New Lesson",goal:"",blocks:[]}]}); sel={c:data.chapters.length-1,l:0}; touch(); render(); }
function renameChapter(ci,v){ data.chapters[ci].title=v; touch(); }
function addLesson(ci){ data.chapters[ci].lessons.push({id:uid(),code:"0.0",title:"New Lesson",goal:"",blocks:[]}); sel={c:ci,l:data.chapters[ci].lessons.length-1}; touch(); render(); }

/* ---------- edit mode ---------- */
function renderEdit(){
  const L=curLesson();
  let h=`<div class="lhead">
    <input class="code" value="${escAttr(L.code)}" onchange="setField('code',this.value)" placeholder="2.1">
    <input class="title" value="${escAttr(L.title)}" onchange="setField('title',this.value)" placeholder="Lesson title">
  </div>
  <input class="goalin" value="${escAttr(L.goal)}" onchange="setField('goal',this.value)" placeholder="Goal: by the end you can…  (HTML allowed, e.g. <b>bold</b>)">`;
  L.blocks.forEach((b,i)=>{ h+=blockEditor(b,i,L.blocks.length); });
  h+=`<div class="addbar"><span class="lbl">Insert a block</span>${Object.entries(BLOCK_KINDS).map(([k,v])=>`<button onclick="addBlock('${k}')">+ ${v.label}</button>`).join('')}</div>`;
  document.getElementById('main').innerHTML=h;
}
function blockEditor(b,i,n){
  let inner='';
  if(b.type==='h') inner=`<input class="f" value="${escAttr(b.text||'')}" oninput="upd(${i},'text',this.value)" placeholder="Section heading">`;
  else if(b.type==='p') inner=`<textarea rows="3" oninput="upd(${i},'html',this.value)" placeholder="Paragraph text — HTML allowed (<strong>, <code>, <em>)">${escHtml(b.html||'')}</textarea>`;
  else if(b.type==='code') inner=`<div class="lbl">Java code</div><textarea class="mono" oninput="upd(${i},'code',this.value)" placeholder="int x = 5;">${escHtml(b.code||'')}</textarea><div class="lbl">Expected output (optional)</div><textarea class="mono" style="min-height:50px" oninput="upd(${i},'out',this.value)" placeholder="program output">${escHtml(b.out||'')}</textarea>`;
  else if(b.type==='callout') inner=`<div class="lbl">Style</div><select onchange="upd(${i},'kind',this.value)"><option value="mistake" ${b.kind==='mistake'?'selected':''}>⚠ Common mistake</option><option value="tip" ${b.kind==='tip'?'selected':''}>✓ Tip</option><option value="note" ${b.kind==='note'?'selected':''}>◆ Note</option></select><div class="lbl">Title</div><input class="f" value="${escAttr(b.title||'')}" oninput="upd(${i},'title',this.value)"><div class="lbl">Body</div><textarea rows="2" oninput="upd(${i},'html',this.value)">${escHtml(b.html||'')}</textarea>`;
  else if(b.type==='try') inner=`<div class="lbl">Exercise prompt</div><textarea rows="2" oninput="upd(${i},'html',this.value)">${escHtml(b.html||'')}</textarea><div class="lbl">Meta (stdin / checks)</div><input class="f" value="${escAttr(b.meta||'')}" oninput="upd(${i},'meta',this.value)" placeholder="stdin: one integer · checks: prints n..1">`;
  return `<div class="blk"><div class="bh"><span class="kind">${BLOCK_KINDS[b.type].label}</span><span class="sp"></span>
    <button ${i===0?'disabled':''} onclick="move(${i},-1)" title="up">↑</button>
    <button ${i===n-1?'disabled':''} onclick="move(${i},1)" title="down">↓</button>
    <button class="del" onclick="delBlock(${i})" title="delete">✕</button></div>
    <div class="bb">${inner}</div></div>`;
}
function setField(f,v){ curLesson()[f]=v; touch(); if(f==='title'||f==='code')buildNav(); }
function upd(i,f,v){ curLesson().blocks[i][f]=v; touch(); }
function addBlock(type){ const b={type}; if(type==='callout')b.kind='mistake'; curLesson().blocks.push(b); touch(); renderEdit(); }
function delBlock(i){ curLesson().blocks.splice(i,1); touch(); renderEdit(); }
function move(i,d){ const b=curLesson().blocks; [b[i],b[i+d]]=[b[i+d],b[i]]; touch(); renderEdit(); }

/* ---------- preview mode (mirrors the student reader) ---------- */
function esc(s){return (s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');}
function escHtml(s){return esc(s);} function escAttr(s){return esc(s).replace(/"/g,'&quot;');}
function highlight(raw){let s=esc(raw);const store=[];const stash=(c,t)=>{store.push(`<span class="${c}">${t}</span>`);return `\u0000${store.length-1}\u0000`;};
  s=s.replace(/\/\/[^\n]*/g,m=>stash('cm',m));
  s=s.replace(/&quot;(?:[^&]|&(?!quot;))*?&quot;/g,m=>stash('st',m));
  s=s.replace(/\b(public|private|static|void|class|new|return|if|else|while|for|break|continue|import|true|false|null)\b/g,'<span class="kw">$1</span>');
  s=s.replace(/\b(int|double|boolean|char|String|Scanner)\b/g,'<span class="ty">$1</span>');
  s=s.replace(/\b(\d+\.?\d*)\b/g,'<span class="nm">$1</span>');
  return s.replace(/\u0000(\d+)\u0000/g,(_,i)=>store[+i]);}
function renderPreview(){
  const L=curLesson();
  let h=`<div class="pv"><h1>${escHtml(L.code)} · ${escHtml(L.title)}</h1>${L.goal?`<div class="goal"><strong>Goal:</strong> ${L.goal}</div>`:''}`;
  L.blocks.forEach(b=>{
    if(b.type==='h') h+=`<h2>${escHtml(b.text||'')}</h2>`;
    else if(b.type==='p') h+=`<p>${b.html||''}</p>`;
    else if(b.type==='code') h+=`<div class="codeblock"><pre>${highlight(b.code||'')}</pre>${b.out?`<div class="out">${esc(b.out)}</div>`:''}</div>`;
    else if(b.type==='callout'){const icon={mistake:'⚠',tip:'✓',note:'◆'}[b.kind||'note'];h+=`<div class="callout ${b.kind||'note'}"><div class="ch">${icon} ${escHtml(b.title||'')}</div><p style="margin:0">${b.html||''}</p></div>`;}
    else if(b.type==='try') h+=`<div class="tryit"><div class="ch">▶ Try it yourself</div><p style="margin:0">${b.html||''}</p>${b.meta?`<div style="font-family:'JetBrains Mono',monospace;font-size:10px;color:var(--muted);margin-top:6px">${escHtml(b.meta)} · runs in the coding exercise + scratchpad</div>`:''}</div>`;
  });
  h+='</div>';
  document.getElementById('main').innerHTML=h;
}
function setMode(m){ mode=m; render(); }

/* ---------- export / import / reset (your data, your control) ---------- */
function exportJSON(){ showModal('Your curriculum (JSON — copy it anywhere)', JSON.stringify(data,null,2), null); }
function importJSON(){ showModal('Paste curriculum JSON to load it', '', ()=>{ try{ data=JSON.parse(document.getElementById('modalText').value); sel={c:0,l:0}; touch(); render(); }catch(e){ alert('Invalid JSON'); } }); }
function resetAll(){ if(confirm('Reset to the demo curriculum? Your edits will be lost.')){ data=seed(); sel={c:0,l:0}; touch(); render(); } }
function showModal(title,text,onOk){ document.getElementById('modalTitle').textContent=title; document.getElementById('modalText').value=text; document.getElementById('modalbg').style.display='flex'; document.getElementById('modalOk').onclick=()=>{ if(onOk)onOk(); closeModal(); }; }
function closeModal(){ document.getElementById('modalbg').style.display='none'; }

load();
</script>
</body>
</html>
</file>

